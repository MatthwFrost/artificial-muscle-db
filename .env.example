# Copy to .env and fill in values. Never commit .env.

# Database
POSTGRES_DB=muscle_db
POSTGRES_USER=muscle
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Firecrawl
FIRECRAWL_API_KEY=fc-your-key-here
FIRECRAWL_API_URL=https://api.firecrawl.dev

# Spark model (Firecrawl's extraction tier — confirm endpoint during setup)
SPARK_MODEL=spark-1-pro

# API
API_HOST=0.0.0.0
API_PORT=8000
API_READ_ONLY_TOKEN=optional_token_for_public_reads
API_ADMIN_TOKEN=strong_admin_token

# Extractor behavior
EXTRACTOR_MAX_CONCURRENCY=2
EXTRACTOR_TIMEOUT_SECONDS=120
EXTRACTOR_RETRY_MAX=3

# Logging
LOG_LEVEL=INFO
